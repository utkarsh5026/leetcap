{
  "name": "leetcap",
  "version": "0.1.0",
  "packageManager": "bun@1.3.11",
  "description": "Chrome extension that captures metadata from accepted LeetCode submissions and copies a formatted comment block to the clipboard.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.6",
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/chrome": "^0.0.268",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
