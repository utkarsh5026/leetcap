{
  "name": "leetcap",
  "version": "0.1.0",
  "packageManager": "bun@1.3.11",
  "description": "Chrome extension that captures metadata from accepted LeetCode submissions and copies a language-specific comment block plus editor code to the clipboard.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && ./scripts/copy-dist-to-windows.sh --optional",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/chrome": "^0.1.42",
    "lefthook": "^2.1.6",
    "prettier": "^3.6.2",
    "typescript": "^5.5.4",
    "vite": "^8.0.10"
  }
}
